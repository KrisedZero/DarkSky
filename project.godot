; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Pixel Horror Castle"
config/description="Top-down pixel-art horror survival. See docs/ for design."
config/version="1.0.0-rc1"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"

[audio]

bus_layout="res://default_bus_layout.tres"

[autoload]

SignalBus="*res://scripts/signal_bus.gd"
Config="*res://scripts/config.gd"
InputReader="*res://scripts/input_reader.gd"
SceneLoader="*res://scripts/scene_loader.gd"
GameManager="*res://scripts/game_manager.gd"
InteractionController="*res://scripts/interaction_controller.gd"
InventoryManager="*res://scripts/inventory_manager.gd"
ItemManager="*res://scripts/item_manager.gd"
SaveManager="*res://scripts/save_manager.gd"
DangerSense="*res://scripts/danger_sense.gd"
SettingsManager="*res://scripts/settings_manager.gd"
AchievementManager="*res://scripts/achievement_manager.gd"
AudioManager="*res://scripts/audio_manager.gd"
ScreenShake="*res://scripts/screen_shake.gd"

[display]

window/size/viewport_width=320
window/size/viewport_height=180
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/scale_mode="integer"

[global]

pixel_horror/tile_size=32

